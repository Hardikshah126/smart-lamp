# .env — Smart Lamp Project
# Copy this file and fill in your real values.
# NEVER commit the real .env to GitHub — only commit .env.example

# ── MQTT ──────────────────────────────────────────────────────
MQTT_BROKER=broker.hivemq.com
MQTT_PORT=1883

# ── ThingSpeak ────────────────────────────────────────────────
THINGSPEAK_WRITE_API_KEY=YOUR_WRITE_API_KEY_HERE
THINGSPEAK_READ_API_KEY=YOUR_READ_API_KEY_HERE
THINGSPEAK_CHANNEL_ID=YOUR_CHANNEL_ID_HERE

# ── Blynk ─────────────────────────────────────────────────────
BLYNK_AUTH_TOKEN=YOUR_BLYNK_AUTH_TOKEN_HERE

# ── Backend ───────────────────────────────────────────────────
BACKEND_PORT=8000

# ── ML Model ──────────────────────────────────────────────────
MODEL_PATH=../ml/model.h5
CONFIDENCE_THRESHOLD=0.65
